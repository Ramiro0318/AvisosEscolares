                    <Border Background="AliceBlue" Padding="12" Stroke="#D1D1D1" StrokeShape="20">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <Label Text="Ramiro Ronaldo Rodríguez Valverde" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="221G0321" />

                            <ImageButton Grid.Column="1" Source="dots.png" Clicked="OnShowCustomMenu" BackgroundColor="Transparent" />
                        </Grid>
                    </Border>
                    <Border Background="AliceBlue" Padding="12" Stroke="#D1D1D1" StrokeShape="20">
