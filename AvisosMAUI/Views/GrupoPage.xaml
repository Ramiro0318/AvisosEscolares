                            <Label Text="Ramiro Ronaldo Rodríguez Valverde" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="221G0321" />

                            <ImageButton Grid.Column="1" Source="dots.png" Clicked="OnShowCustomMenu" BackgroundColor="Transparent" />
                        </Grid>
                    </Border>
                    <Border Background="AliceBlue" Padding="12" Stroke="#D1D1D1" StrokeShape="20">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <Label Text="Ramiro Ronaldo Rodríguez Valverde" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="221G0321" />

                            <ImageButton Grid.Column="1" Source="dots.png" Clicked="OnShowCustomMenu" BackgroundColor="Transparent" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>


            <Button x:Name="Escudo"  BackgroundColor="Transparent" BorderColor="Transparent" IsVisible="False" Clicked="OnCloseCustomMenu" />

            <Border x:Name="MiMenuFlotante" IsVisible="False" ZIndex="10" BackgroundColor="White" Stroke="Gray" StrokeShape="10" WidthRequest="150" HeightRequest="100" HorizontalOptions="Start" VerticalOptions="Start" Margin="0,50,20,0" Shadow="{Shadow Brush=Black, Offset='5,5', Radius=10, Opacity=0.2}">
                <VerticalStackLayout Padding="5">
                    <Button Text="Editar" BackgroundColor="Transparent" TextColor="Black" />
                    <BoxView HeightRequest="1" Color="LightGray" />
                    <Button Text="Eliminar" BackgroundColor="Transparent" TextColor="Red" />
                </VerticalStackLayout>
            </Border>
        </Grid>


