<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:AvisosMAUI.Views"
             x:Class="AvisosMAUI.Views.GrupoPage" NavigationPage.HasNavigationBar="False"
             Title="">
    <Grid RowDefinitions="Auto, Auto, *" x:Name="ContenidoGrid">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnFondoTapped" />
        </Grid.GestureRecognizers>
        <Grid Grid.Row="0" BackgroundColor="#26A69A" Padding="15,0" HeightRequest="55" ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Entry Grid.Column="0" Text="Grupo de clases" IsReadOnly="True" TextColor="White" FontSize="20" FontAttributes="Bold" Background="Transparent" VerticalOptions="Center"/>
            <ImageButton Grid.Column="1" Source="edit.png" BackgroundColor="Transparent" HeightRequest="40" WidthRequest="40" Margin="0,0,10,0"/>
            <ImageButton Grid.Column="2" Source="whitedots.png" BackgroundColor="Transparent" BorderColor="Transparent" HeightRequest="40" WidthRequest="40" Clicked="OnToggleMenuClicked" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" Margin="5,0">
            <Label Margin="15,0" FontSize="18">Buscar alumno:</Label>
            <SearchBar Text="{Binding Busqueda}" SearchCommand="{Binding FiltrarCommand}" ></SearchBar>
        </VerticalStackLayout>
        <Grid Grid.Row="2">
            <CollectionView x:Name="ListaAlumnos" ItemsSource="{Binding ListaAlumnos}" SelectionMode="Single" Margin="20,5">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="3"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Ver avisos" Command="{Binding BindingContext.VerDetallesAlumnoCommand, Source={x:Reference ListaAlumnos}}" CommandParameter="{Binding .}" BackgroundColor="Purple"  />
                                    <SwipeItem Text="Enviar aviso" BackgroundColor="#26A69A" Command="{Binding BindingContext.VerCrearAvisoPersonalCommand, Source={x:Reference ListaAlumnos}}" CommandParameter="{Binding .}"  />
                                    <SwipeItem Text="Editar" Command="{Binding BindingContext.VerEditarAlumnoCommand, Source={x:Reference ListaAlumnos}}" CommandParameter="{Binding .}" BackgroundColor="LightGray"  />
                                    <SwipeItem Text="Eliminar" Command="{Binding BindingContext.VerEliminarAlumnoCommand, Source={x:Reference ListaAlumnos}}" CommandParameter="{Binding .}" BackgroundColor="Red" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Background="AliceBlue" Padding="12" Stroke="#D1D1D1" StrokeShape="RoundRectangle 20">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Nombre}" FontAttributes="Bold" />
                                    <Label Text="{Binding NumControl}" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border x:Name="MenuDesplegable" IsVisible="False" BackgroundColor="White" Stroke="LightGray" StrokeShape="RoundRectangle 8" WidthRequest="180" HorizontalOptions="End" VerticalOptions="Start" Margin="0,5,15,0" ZIndex="10" InputTransparent="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="5,5" Radius="10" Opacity="0.1" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">
                    <Button Text="Agregar alumno" Command="{Binding VerRegistrarAlumnoCommand}" BackgroundColor="Transparent" TextColor="Black" HorizontalOptions="Fill">
                        <Button.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFondoTapped" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Text="Actualizar lista" Command="{Binding CargarClaseCommand}" BackgroundColor="Transparent" TextColor="Black" HorizontalOptions="Fill">
                        <Button.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFondoTapped" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Text="Enviar aviso general" Command="{Binding VerCrearAvisoGeneralCommand}" BackgroundColor="Transparent" TextColor="Black" HorizontalOptions="Fill">
                        <Button.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFondoTapped" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Text="Ver avisos generales" Command="{Binding VerAvisosGeneralesMaestroCommand}" BackgroundColor="Transparent" TextColor="Black" HorizontalOptions="Fill">
                        <Button.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFondoTapped" />
                        </Button.GestureRecognizers>
                    </Button>
                    <Button Text="Salir" BackgroundColor="Transparent" TextColor="Red" HorizontalOptions="Fill">
                        <Button.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFondoTapped" />
                        </Button.GestureRecognizers>
                    </Button>
                </VerticalStackLayout>
            </Border>
        </Grid>
        <views:LoadingPage Grid.RowSpan="3" ZIndex="10"></views:LoadingPage>
        
        <Grid BackgroundColor="#66000000" ZIndex="11" Grid.RowSpan="3">
            <Grid.Triggers>
                <DataTrigger TargetType="Grid" Binding="{Binding Eliminando}" Value="True">
                    <Setter Property="IsVisible" Value="True"></Setter>
                </DataTrigger>
                <DataTrigger TargetType="Grid" Binding="{Binding Eliminando}" Value="False">
                    <Setter Property="IsVisible" Value="False"></Setter>
                </DataTrigger>
            </Grid.Triggers>

            <VerticalStackLayout Spacing="20" Background="AliceBlue" Padding="10, 30" VerticalOptions="Center" HorizontalOptions="Fill" TranslationY="-20">
                <Label Text="Confirmar eliminación" TextColor="Black" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button Text="Cancelar" BackgroundColor="LightGray"/>
                    <Button Text="Eliminar" BackgroundColor="Red" TextColor="White"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>