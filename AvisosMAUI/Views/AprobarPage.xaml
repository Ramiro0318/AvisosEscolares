<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:AvisosMAUI.Views"
             x:Class="AvisosMAUI.Views.AprobarPage" NavigationPage.HasNavigationBar="False"
             Title="">
    <ScrollView>
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, 25, *" RowSpacing="8" VerticalOptions="Fill">

            <HorizontalStackLayout Grid.Row="0" BackgroundColor="#26A69A" Padding="10,0" HeightRequest="55" Spacing="10">
                <ImageButton Source="arrow.png" BackgroundColor="Transparent" BorderColor="Transparent" HorizontalOptions="Start"></ImageButton>
                <Label Text="Revisar solicitud" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Vista}" Value="Editar">
                            <Setter Property="Text" Value="Editar alumno" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </HorizontalStackLayout>

            <Label  Grid.Row="1" Margin="30,5, 30, 0">Nombre:</Label>
            <Entry  Grid.Row="2" Margin="30,0" IsReadOnly="True">
                <Entry.Triggers>
                    <DataTrigger TargetType="Entry" Binding="{Binding Vista}" Value="Editar">
                        <Setter Property="IsReadOnly" Value="True" />
                    </DataTrigger>
                </Entry.Triggers>
            </Entry>
            
            <Label  Grid.Row="3" Margin="30,0">Num de control:</Label>
            <Entry  Grid.Row="4" Margin="30,0" IsReadOnly="True">
                <Entry.Triggers>
                    <DataTrigger TargetType="Entry" Binding="{Binding Vista}" Value="Editar">
                        <Setter Property="IsReadOnly" Value="True" />
                    </DataTrigger>
                </Entry.Triggers>
            </Entry>
            
            <Label Grid.Row="5" Margin="30,0">Correo:</Label>
            <Entry Grid.Row="6" Margin="30,0" Keyboard="Email" IsReadOnly="True">
                <Entry.Triggers>
                    <DataTrigger TargetType="Entry" Binding="{Binding Vista}" Value="Editar">
                        <Setter Property="IsReadOnly" Value="True" />
                    </DataTrigger>
                </Entry.Triggers>
            </Entry>
            
            <Label Grid.Row="7" Margin="30,0" TextColor="Red" IsVisible="True" MaximumWidthRequest="350" HorizontalOptions="Start" VerticalOptions="Center">Mensaje de error</Label>

            <HorizontalStackLayout Grid.Row="9" Spacing="5" Margin="30, 20" VerticalOptions="End" HorizontalOptions="End">
                <Button Text="Cancelar"></Button>
                <Button Text="Rechazar" Background="Red" TextColor="White">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding Vista}" Value="Editar">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Aprobar" TextColor="White" Background="#26A69A">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding Vista}" Value="Editar">
                            <Setter Property="Text" Value="Editar" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>
            <views:LoadingPage Grid.RowSpan="9" ZIndex="10"></views:LoadingPage>
        </Grid>
    </ScrollView>
</ContentPage>