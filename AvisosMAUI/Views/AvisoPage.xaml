<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosMAUI.Views.AvisoPage" 
             xmlns:views="clr-namespace:AvisosMAUI.Views"
             NavigationPage.HasNavigationBar="False"
             Title="">
    <Grid RowDefinitions="Auto, *" RowSpacing="10" Background="AliceBlue">
        <Grid Grid.Row="0" BackgroundColor="#26A69A" Padding="10,0" HeightRequest="55">
            <FlexLayout JustifyContent="SpaceBetween" AlignItems="Center">
                <ImageButton Source="arrow.png" Command="{Binding VolverDetallesAvisoCommand}" BackgroundColor="Transparent" BorderColor="Transparent"></ImageButton>
            </FlexLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10,0">
                <Border Background="White" Padding="12" Stroke="Black" StrokeShape="10">
                    <Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                        <Label Grid.Row="0" Text="{Binding AvisoPersonalDetallesModel.Titulo}" Padding="10,0" FontAttributes="Bold" VerticalOptions="Center" LineBreakMode="WordWrap"/>
                        <Label Grid.Row="2" Text="{Binding AvisoPersonalDetallesModel.Contenido}" Padding="10,0" Margin="0, 1, 0, 0"></Label>
                        <Label Grid.Row="3" FontSize="15" HorizontalOptions="End" Margin="0,20,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Fecha enviado: " TextColor="Gray"  />
                                    <Span Text="{Binding AvisoPersonalDetallesModel.FechaCreacion, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Grid.Row="4" FontSize="15" HorizontalOptions="End">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Fecha lectura: "  TextColor="Gray" />
                                    <Span Text="{Binding AvisoPersonalDetallesModel.FechaLectura, StringFormat='{0:dd/MM/yyyy hh:mm tt}' }"  />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <views:LoadingPage Grid.RowSpan="2" ZIndex="10"></views:LoadingPage>
    </Grid>
</ContentPage>