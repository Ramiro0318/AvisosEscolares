<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AvisosMAUI.Views.AvisoPage" NavigationPage.HasNavigationBar="False"
             Title="" Background="AliceBlue">
    <VerticalStackLayout Spacing="10">
        <!--#FFA69A-->
        <Grid BackgroundColor="#26A69A" Padding="10,0" HeightRequest="55">
            <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Center" Spacing="8">
                <Label Text="Pasar a entregar documentación" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" LineBreakMode="WordWrap"/>
                <Border Background="Red" Padding="4,0" StrokeShape="4" IsVisible="True">
                    <Label Text="◉" TextColor="White" FontSize="13"></Label>
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <Label Text="12 de abril 2024" HorizontalOptions="End" Padding="10,0"></Label>
        <Label Padding="10,0">Se le solicita a todos los alumnos pasar a entregar su documentación personal de alta, así como su cardex y certificado de la primaria.</Label>
    </VerticalStackLayout>
</ContentPage>