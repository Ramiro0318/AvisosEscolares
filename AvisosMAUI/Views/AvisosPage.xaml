    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="*, *" HeightRequest="50" BackgroundColor="#F0F0F0">
            <Button x:Name="BtnGenerales" 
                Text="GENERALES" 
                Grid.Column="0"
                BackgroundColor="#26A69A" 
                TextColor="White"
                CornerRadius="0"
                Clicked="OnTabClicked"/>

            <Button x:Name="BtnPersonales" 
                Text="PERSONALES" 
                Grid.Column="1"
                BackgroundColor="Transparent" 
                TextColor="Gray"
                CornerRadius="0"
                Clicked="OnTabClicked"/>
        </Grid>

        <Grid Grid.Row="1">
            <VerticalStackLayout x:Name="ViewGenerales" IsVisible="True" Padding="20">
                <Label Text="Aquí va tu CollectionView de siempre" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="ViewPersonales" IsVisible="False" Padding="20">
                <Label Text="Aquí van tus avisos privados" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
