<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:AvisosMAUI.Views"   
             x:Class="AvisosMAUI.Views.AlumnoPage" NavigationPage.HasNavigationBar="False"
             Title="">
    <Grid RowDefinitions="Auto, *">

        <HorizontalStackLayout Grid.Row="0" BackgroundColor="#26A69A" Padding="10,0" HeightRequest="55" Spacing="10">
            <ImageButton Source="arrow.png" Command="{Binding RegresarCommand}" HorizontalOptions="Start" BackgroundColor="Transparent" BorderColor="Transparent"></ImageButton>
            <Label Text="Historial de avisos" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="White"></Label>
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout  Spacing="8" Padding="20">
                <Border Background="#D2DCE4" Margin="-21, -21, -21, 0">
                    <VerticalStackLayout Grid.Row="1" Spacing="5" Padding="20, 5, 20, 20" >
                        <Label>Nombre:</Label>
                        <Entry Text="{Binding AlumnoDetallesModel.Nombre}" IsReadOnly="True"></Entry>
                        <Label>Num de control:</Label>
                        <Entry Text="{Binding AlumnoDetallesModel.NumControl}" IsReadOnly="True"></Entry>
                        <Label>Correo:</Label>
                        <Entry Text="{Binding AlumnoDetallesModel.Correo}" IsReadOnly="True"></Entry>
                        <BoxView HeightRequest="1" Color="#FF899092" HorizontalOptions="Fill" Margin="-20, 10, -20, -20" ></BoxView>
                    </VerticalStackLayout>
                </Border>


                <CollectionView SelectionMode="Single" ItemsSource="{Binding AlumnoDetallesModel.ListaAvisosAlumno}" VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="9"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="AliceBlue" Padding="12" Stroke="Black" StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerDetallesAvisoPersonalMaestroCommand}" CommandParameter="{Binding .}"></TapGestureRecognizer>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
                                    <Label Grid.Row="0" Text="{Binding Titulo}" FontAttributes="Bold"/>
                                    <ImageButton Grid.Row="0" Grid.Column="1" Source="trash.png" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.VerEliminarAvisoPersonalCommand}" CommandParameter="{Binding .}" HorizontalOptions="End" BackgroundColor="Transparent"></ImageButton>
                                    <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Contenido}" Margin="0,0,50,0" LineBreakMode="TailTruncation"/>
                                    <Label Grid.Row="2" Grid.ColumnSpan="2" TextColor="DimGray" Margin="0, 5, 0, 0" FontSize="13" HorizontalOptions="End">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Enviado el: " />
                                                <Span Text="{Binding FechaCreacion}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        <views:LoadingPage Grid.RowSpan="2" ZIndex="10"></views:LoadingPage>
        <Grid BackgroundColor="#66000000" Grid.RowSpan="3" ZIndex="11">
            <Grid.Triggers>
                <DataTrigger TargetType="Grid" Binding="{Binding Eliminando}" Value="True">
                    <Setter Property="IsVisible" Value="True"></Setter>
                </DataTrigger>
                <DataTrigger TargetType="Grid" Binding="{Binding Eliminando}" Value="False">
                    <Setter Property="IsVisible" Value="False"></Setter>
                </DataTrigger>
            </Grid.Triggers>

            <Border Background="AliceBlue" Padding="10, 30" StrokeShape="RoundRectangle 8" Margin="24, 0" VerticalOptions="Center" HorizontalOptions="Fill" TranslationY="-20">
                <VerticalStackLayout Spacing="20" Background="AliceBlue" >
                    <Label Text="Confirmar eliminación" TextColor="Black" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button Text="Cancelar" Command="{Binding CancelarEliminarCommand}" BackgroundColor="LightGray"/>
                        <Button Text="Eliminar" Command="{Binding EliminarAvisoPersonalCommand}" BackgroundColor="Red" TextColor="White"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>